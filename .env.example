# Источник данных приложения.
# mock  — данные из локальных файлов и localStorage (по умолчанию).
# http  — реальный бэкенд по адресу VITE_API_URL.
VITE_API_MODE=mock

# Базовый URL реального API (используется при VITE_API_MODE=http).
# VITE_API_URL=https://api.mabl.ru

# --- Серверные переменные (Vercel / Neon), во фронтенд не попадают ---

# Публичный Telegram-канал академии, из которого автоматически подтягиваются
# новости с картинками. Укажите @username (можно без «@» или полной ссылкой).
# TELEGRAM_CHANNEL=mabl_academy

# Строка подключения к базе Neon (обычно проставляется интеграцией Vercel ↔ Neon).
# DATABASE_URL=postgres://...

# Секрет для одноразовой инициализации БД через POST /api/setup?secret=...
# SETUP_SECRET=change-me

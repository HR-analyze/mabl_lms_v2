# --- Фронтенд (Vite) ---
# Источник данных приложения.
# mock — данные из локальных файлов и localStorage (по умолчанию).
# http — реальный бэкенд по адресу VITE_API_URL.
VITE_API_MODE=mock

# Базовый URL API. Для бэкенда в этом же проекте (Vercel Functions) — /api.
VITE_API_URL=/api

# --- Бэкенд (Vercel Functions) ---
# Строка подключения к Postgres. На Vercel задаётся автоматически при
# подключении Postgres-хранилища (Storage → Postgres). Для локали — из Neon/Vercel.
# POSTGRES_URL=postgres://user:password@host/db?sslmode=require

# Секрет для подписи JWT (обязательно задать в проде — длинная случайная строка).
# JWT_SECRET=change-me-to-a-long-random-string

# Ключ для разовой настройки БД через POST /api/setup?secret=...
# Задайте временно, вызовите эндпоинт один раз, затем удалите переменную.
# SETUP_SECRET=one-time-random-key
